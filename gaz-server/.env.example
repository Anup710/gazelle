# Gazelle Backend — environment template.
# Copy this file to `.env` and fill in real values. Never commit `.env`.
#
# Boot-time required (uvicorn will fail to start without these four):
#   - SUPABASE_URL / SUPABASE_KEY  → first request to /sessions reads from jobs table
#   - QDRANT_URL  / QDRANT_API_KEY → lifespan hook creates the collection on boot
#
# Job-time required (only when the first ingest/query runs):
#   - OPENAI_API_KEY (embeddings, GPT-4o-mini, TTS)
#   - GROQ_API_KEY   (Whisper for ASR + voice queries)

# --- Required ---------------------------------------------------------------

# OpenAI: https://platform.openai.com/api-keys  (needs billing enabled)
OPENAI_API_KEY=

# Groq: https://console.groq.com/keys  (free tier is fine)
GROQ_API_KEY=

# Supabase: Project Settings → API
#   SUPABASE_URL = "Project URL" (e.g. https://abcdefghij.supabase.co)
#   SUPABASE_KEY = "service_role" key (NOT the anon key — this bypasses RLS, server-only)
SUPABASE_URL=
SUPABASE_KEY=

# Qdrant Cloud: cluster overview page
#   QDRANT_URL must include the port :6333
#   QDRANT_API_KEY: API Keys → Create
QDRANT_URL=
QDRANT_API_KEY=

# CORS allow-list — comma separated. Vite dev origin baseline.
# Add your Vercel production URL once deployed.
ALLOWED_ORIGINS=http://localhost:5173

# --- Optional overrides (sane defaults exist in code) -----------------------

# QDRANT_COLLECTION=transcript_chunks
# EMBED_MODEL=text-embedding-3-small
# GEN_MODEL=gpt-4o-mini
# GROQ_WHISPER_MODEL=whisper-large-v3-turbo
# TTS_MODEL=tts-1
# TTS_VOICE=alloy
# MIN_SIMILARITY_SCORE=0.72
# TOP_K=5
# LOG_LEVEL=INFO
